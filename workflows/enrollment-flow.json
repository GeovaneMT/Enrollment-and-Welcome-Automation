    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body\n\nconst errors = [];\n\nconst isValidEmail = (email) => {\n  return /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(email);\n};\n\nconst isValidPhone = (phone) => {\n  const cleaned = phone.replace(/\\D/g, '');\n  return cleaned.length >= 10 && cleaned.length <= 15;\n};\n\nconst isValidDate = (date) => {\n  const match = /^(\\d{2})\\/(\\d{2})\\/(\\d{4})$/.exec(date);\n  if (!match) return false;\n\n  const day = parseInt(match[1], 10);\n  const month = parseInt(match[2], 10);\n  const year = parseInt(match[3], 10);\n\n  if (month < 1 || month > 12) return false;\n\n  const daysInMonth = new Date(year, month, 0).getDate();\n\n  return day >= 1 && day <= daysInMonth;\n};\n\nconst normalizeName = (name) =>\n  name.toLowerCase().replace(/\\b\\w/g, l => l.toUpperCase());\n\nconst normalizePhone = (phone) =>\n  phone.replace(/\\D/g, '');\n\nconst normalizeDate = (date) => {\n  const [day, month, year] = date.split('/');\n  return `${year}-${month.padStart(2,'0')}-${day.padStart(2,'0')}`;\n};\n\nif (!body.curso_escolhido) errors.push(\"curso is required\");\nif (!body.email_aluno) errors.push(\"email is required\");\nif (!body.telefone) errors.push(\"telefone is required\");\nif (!body.nome_completo) errors.push(\"nome_completo is required\");\nif (!body.data_nascimento) errors.push(\"data_nascimento is required\");\n\nif (body.email && !isValidEmail(body.email)) {\n  errors.push(\"invalid email format\");\n}\n\nif (body.telefone && !isValidPhone(body.telefone)) {\n  errors.push(\"invalid phone number\");\n}\n\nif (body.data_nascimento && !isValidDate(body.data_nascimento)) {\n  errors.push(\"invalid birth date format (DD/MM/YYYY expected)\");\n}\n\nconst course = body.curso?.toLowerCase();\n\nif (course && ![\"tech\", \"business\"].includes(course)) {\n  errors.push(\"invalid course (must be tech or business)\");\n}\n\nif (errors.length > 0) {\n  return [\n    {\n      json: {\n        valid: false,\n        errors\n      }\n    }\n  ];\n}\n\nreturn [\n  {\n    json: {\n      valid: true,\n      data: {\n        email: body.email_aluno.toLowerCase(),\n        phone: normalizePhone(body.telefone),\n        name: normalizeName(body.nome_completo),\n        birthDate: normalizeDate(body.data_nascimento),\n        course\n      }\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
