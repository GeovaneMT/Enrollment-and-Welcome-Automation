        "jsCode": "const { course, email, phone, fullName, birthDate } =  $input.first().json\n\nconst nameFormater = (name) => {\n  return name.toLowerCase()\n    .replace(/\\b\\w/g, l => l.toUpperCase());\n}\n\nconst phoneFormater = (phone) => {\n  return phone.replace(/\\D/g, '');\n}\n\nconst dateFormater = (birthDate) => {\n  birthDate;\n  const [day, month, year] = birthDate.split('/');\n  return `${year}-${month.padStart(2, '0')}-${day.padStart(2, '0')}`;\n}\n\nconst emailFormater = (email) => {\n  return email.toLowerCase()\n}\n\nconst courseFormater = (course) => {\n  return course.toLowerCase()\n}\n\nconst formatedPhone = phoneFormater(phone);\nconst formatedName = nameFormater(fullName);\nconst formatedDate = dateFormater(birthDate);\nconst formatedEmail = emailFormater(email)\nconst formatedCourse = courseFormater(course)\n\nreturn [{\n  json: {\n    email: formatedEmail,\n    birthDate: formatedDate,\n    name: formatedName,\n    phone: formatedPhone,\n    course: formatedCourse,\n  }\n}];"
      },
